# alias gpr2dirlist="/workspaces/bench-source/gpr_to_source_dirs/bin/gpr_to_source_dirs"
# alias gpr2withlist="/workspaces/bench-source/gpr_to_source_dirs/bin/gpr_with_extract"
alias cogralys-bench-util="deno run --config /workspaces/bench-source/deno.jsonc --allow-all --unsafely-ignore-certificate-errors --unstable --v8-flags=--max-old-space-size=16384 /workspaces/bench-source/utils/cogralys-bench-util.ts"
alias checkRunningJobPopulateDb="deno run --config /workspaces/bench-source/deno.jsonc --allow-all --unstable --v8-flags=--max-old-space-size=16384 /workspaces/bench-source/utils/checkRunningJobPopulateDb.ts"
alias rmi="rm *.ali *.adt"
alias clocAda="tokei -n underscores -t=Ada $@"
alias alb="alr -n build"
alias alu="alr -n update"
alias ls="ls --color $@"
alias l="ls --color -ali $@"